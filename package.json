    "typescript": "6.0.3",
    "wrangler": "4.105.0"
  },
  "overrides": {
    "@babel/core": "8.0.1",
    "@babel/generator": "8.0.0",
    "@babel/helper-module-imports": "8.0.0",
    "@babel/parser": "8.0.0",
    "@babel/template": "8.0.0",
    "@babel/traverse": "8.0.0",
    "@babel/types": "8.0.0",
    "@jridgewell/trace-mapping": "0.3.31",
    "esbuild": "0.28.1",
    "glob": "13.0.6",
    "is-docker": "4.0.0",
